@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<!-- Fondo uniforme con ligera textura -->
<section class="vh-100 d-flex align-items-center bg-body text-body" 
         style="background: linear-gradient(to right, var(--bs-body-bg), var(--bs-body-bg));">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <!-- Card con fondo claro/oscuro adaptativo -->
                <div class="card shadow border-0" style="border-radius: 1rem;">
                    <div class="row g-0">
                        <!-- Imagen lateral -->
                        <div class="col-md-6 col-lg-5 d-none d-md-block">
                            <img src="~/uploads/img/Sin título.png"
                                 alt="login form"
                                 class="img-fluid"
                                 style="border-radius: 1rem 0 0 1rem;
                                        object-fit: cover;
                                        object-position: right center;
                                        height: 100%;" />
                        </div>
                        <!-- Formulario -->
                        <div class="col-md-6 col-lg-7 d-flex align-items-center">
                            <div class="card-body p-4 p-lg-5">
                                <form id="account" method="post">
                                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                                    <!-- Logo corporativo -->
                                    <div class="d-flex align-items-center mb-3 pb-1">
                                        <img src="~/uploads/logos/logo-dark.png" alt="Logo Kimberly-Clark"
                                             style="height: 50px;" />
                                    </div>

                                    <h5 class="fw-normal mb-3 pb-3">Inicia sesión en tu cuenta</h5>

                                    <div class="form-outline mb-4">
                                        <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" aria-required="true" />
                                        <label asp-for="Input.Email" class="form-label">Correo electrónico</label>
                                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                                    </div>

                                    <div class="form-outline mb-4">
                                        <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="current-password" aria-required="true" />
                                        <label asp-for="Input.Password" class="form-label">Contraseña</label>
                                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                                    </div>

                                    <div class="form-check mb-4">
                                        <input class="form-check-input" asp-for="Input.RememberMe" />
                                        <label asp-for="Input.RememberMe" class="form-check-label">
                                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                                        </label>
                                    </div>

                                    <div class="pt-1 mb-4">
                                        <button id="login-submit" type="submit" class="btn btn-primary btn-lg btn-block">Ingresar</button>
                                    </div>

                                    <a id="forgot-password" asp-page="./ForgotPassword" class="small text-muted">¿Olvidaste tu contraseña?</a>
                                    <p class="mb-5 pb-lg-2">
                                        ¿No tienes una cuenta?
                                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Regístrate aquí</a>
                                    </p>
                                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="small text-muted">Reenviar confirmación de correo</a>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
