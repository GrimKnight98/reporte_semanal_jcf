@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="vh-100 bg-body-tertiary">
    <div class="container py-5 h-100">
        <div class="row d-flex justify-content-center align-items-center h-100">
            <div class="col col-xl-10">
                <div class="card shadow" style="border-radius: 1rem;">
                    <div class="row g-0">
                        <!-- Imagen lateral -->
                        <div class="col-md-6 col-lg-5 d-none d-md-block">
                            <img src="~/uploads/img/Sin título.png"
                                 alt="register form"
                                 class="img-fluid"
                                 style="border-radius: 1rem 0 0 1rem;
                                        object-fit: cover;
                                        object-position: right center;
                                        height: 100%;" />
                        </div>
                        <!-- Formulario -->
                        <div class="col-md-6 col-lg-7 d-flex align-items-center">
                            <div class="card-body p-4 p-lg-5 text-body">

                                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                                    <!-- Logo corporativo dark -->
                                    <div class="d-flex align-items-center mb-3 pb-1">
                                        <img src="~/uploads/logos/logo-dark.png" alt="Logo Kimberly-Clark"
                                             style="height: 50px;" />
                                    </div>

                                    <h5 class="fw-normal mb-3 pb-3" style="letter-spacing: 1px;">Crea una nueva cuenta</h5>

                                    <div class="form-outline mb-4">
                                        <input asp-for="Input.Email" class="form-control form-control-lg" autocomplete="username" aria-required="true" />
                                        <label asp-for="Input.Email" class="form-label">Correo electrónico</label>
                                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                                    </div>

                                    <div class="form-outline mb-4">
                                        <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="new-password" aria-required="true" />
                                        <label asp-for="Input.Password" class="form-label">Contraseña</label>
                                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                                    </div>

                                    <div class="form-outline mb-4">
                                        <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg" autocomplete="new-password" aria-required="true" />
                                        <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar contraseña</label>
                                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                                    </div>

                                    <div class="pt-1 mb-4">
                                        <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg btn-block">Registrar</button>
                                    </div>
                                </form>

                                <!-- Servicios externos -->
                                <section class="mt-4">
                                    <h6 class="fw-normal mb-3">Usar otro servicio para registrarse</h6>
                                    @{
                                        if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                        {
                                            <div>
                                                <p class="small text-muted">
                                                    No hay servicios externos configurados. Consulta este
                                                    <a href="https://go.microsoft.com/fwlink/?LinkID=532715">artículo</a>
                                                    para habilitar autenticación externa.
                                                </p>
                                            </div>
                                        }
                                        else
                                        {
                                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                                <div>
                                                    <p>
                                                        @foreach (var provider in Model.ExternalLogins!)
                                                        {
                                                            <button type="submit" class="btn btn-primary me-2 mb-2"
                                                                    name="provider" value="@provider.Name"
                                                                    title="Registrarse con @provider.DisplayName">
                                                                @provider.DisplayName
                                                            </button>
                                                        }
                                                    </p>
                                                </div>
                                            </form>
                                        }
                                    }
                                </section>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
