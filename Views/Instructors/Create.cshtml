@model DemoMvc.Models.Instructor

@{
    ViewData["Title"] = "Create Instructor";
}

<h1 class="mb-4">Nuevo Instructor</h1>

<div class="row">
    <!-- En pantallas grandes se queda a la izquierda, en medianas se centra -->
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <!-- IMPORTANTE: enctype para subir archivos -->
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="PersonNumber" class="form-label fw-bold"></label>
                        <input asp-for="PersonNumber" class="form-control" placeholder="Número de empleado" />
                        <span asp-validation-for="PersonNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-bold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Nombre completo" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Position" class="form-label fw-bold"></label>
                        <input asp-for="Position" class="form-control" placeholder="Puesto" />
                        <span asp-validation-for="Position" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Department" class="form-label fw-bold"></label>
                        <input asp-for="Department" class="form-control" placeholder="Departamento" />
                        <span asp-validation-for="Department" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-bold"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <!-- Campo para subir la firma -->
                    <div class="mb-3">
                        <label for="SignFile" class="form-label fw-bold">Firma</label>
                        <input type="file" name="SignFile" class="form-control" />
                        <!-- No usamos asp-for porque SignPath guarda la ruta, no el archivo -->
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Volver a la lista
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
