@using DemoMvc.Models
@model UsersIndexViewModel

@{
    ViewData["Title"] = "Usuarios";
}

<h1 class="mb-4">Usuarios</h1>

<div class="row">
    <!-- Panel de filtros -->
    <div class="col-md-3">
        <div class="card shadow-sm mb-4 border-primary">
            <div class="card-header bg-primary bg-opacity-25 text-primary fw-bold">
                <i class="fas fa-filter"></i> Filtros de Usuarios
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get">
                    <!-- Búsqueda -->
                    <div class="mb-3">
                        <label for="search" class="form-label fw-bold">Buscar</label>
                        <div class="input-group">
                            <input type="text" name="search" value="@ViewBag.CurrentSearch"
                                   class="form-control" placeholder="Correo, nombre o PersonNumber" />
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Rol -->
                    <div class="mb-3">
                        <label for="roleFilter" class="form-label fw-bold">Rol</label>
                        <select name="roleFilter" id="roleFilter" class="form-select" asp-items="ViewBag.RoleFilterOptions">
                            <option value="">-- Todos --</option>
                        </select>
                    </div>

                    <!-- Estado -->
                    <div class="mb-3">
                        <label for="statusFilter" class="form-label fw-bold">Estado</label>
                        <select name="statusFilter" id="statusFilter" class="form-select" asp-items="ViewBag.StatusFilterOptions">
                            <option value="">-- Todos --</option>
                        </select>
                    </div>

                    <!-- Botón aplicar -->
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter"></i> Aplicar Filtros
                        </button>
                    </div>
                </form>

                <!-- Botón limpiar -->
                @if (!string.IsNullOrWhiteSpace(ViewBag.CurrentSearch) 
                    || !string.IsNullOrWhiteSpace(ViewBag.CurrentRoleFilter) 
                    || !string.IsNullOrWhiteSpace(ViewBag.CurrentStatusFilter))
                {
                    <div class="mt-3">
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">
                            <i class="fas fa-list"></i> Ver todos
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Panel principal -->
    <div class="col-md-9">
        <form asp-action="BulkDelete" method="post" id="bulkDeleteForm">
            <div class="card shadow-sm mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Lista de Usuarios</span>
                    <div>
                        <a asp-action="Create" class="btn btn-sm btn-success me-2">
                            <i class="fas fa-user-plus"></i> Nuevo Usuario
                        </a>
                        <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#confirmBulkDeleteModal">
                            <i class="fas fa-trash-alt"></i> Eliminar seleccionados
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th><input type="checkbox" id="selectAll" /></th>
                                    <th>Email</th>
                                    <th>Nombre completo</th>
                                    <th>Roles</th>
                                    <th>Estado</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Users != null && Model.Users.Any())
                                {
                                    @foreach (var user in Model.Users)
                                    {
                                        <tr>
                                            <td><input type="checkbox" name="ids" value="@user.Id" class="selectItem" /></td>
                                            <td>@user.Email</td>
                                            <td>@user.FullName</td>
                                            <td>
                                                @if (Model.UserRoles != null && Model.UserRoles.ContainsKey(user.Id) && Model.UserRoles[user.Id].Any())
                                                {
                                                    foreach (var role in Model.UserRoles[user.Id])
                                                    {
                                                        switch (role)
                                                        {
                                                            case "SysAdmin":
                                                                <span class="badge bg-danger me-1">SysAdmin</span>;
                                                                break;
                                                            case "JCF":
                                                                <span class="badge bg-primary me-1">JCF</span>;
                                                                break;
                                                            case "Instructor":
                                                                <span class="badge bg-warning text-dark me-1">Instructor</span>;
                                                                break;
                                                            case "RI":
                                                                <span class="badge bg-secondary me-1">Relaciones Industriales</span>;
                                                                break;
                                                            default:
                                                                <span class="badge bg-info text-dark me-1">@role</span>;
                                                                break;
                                                        }
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="badge bg-light text-muted">Sin rol</span>
                                                }
                                            </td>
                                            <td>
                                                @if (user.IsActive)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning me-1">
                                                    <i class="fas fa-edit"></i> Editar
                                                </a>
                                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info me-1">
                                                    <i class="fas fa-eye"></i> Detalles
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash-alt"></i> Eliminar
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted">No hay usuarios registrados.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    @if (!string.IsNullOrWhiteSpace(Context.Request.Query["search"]))
                    {
                        <span>Mostrando @Model.Users.Count() de @Model.TotalCount usuarios encontrados</span>
                    }
                    else
                    {
                        <span>Total de usuarios: @Model.TotalCount</span>
                    }
                    <nav>
                        <ul class="pagination mb-0">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@Context.Request.Query["search"]">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <!-- Panel lateral izquierdo -->
    <div class="col-md-3">
        <div class="card shadow-sm mb-4 border-primary">
            <div class="card-header bg-primary bg-opacity-25 text-primary fw-bold">
                <i class="fas fa-user"></i> Asignar Instructor ↔ JCF
            </div>
            <div class="card-body">
                <form asp-controller="JcfAssignations" asp-action="Create" method="post">
                    <!-- Lista de Instructores activos -->
                    <div class="mb-3">
                        <label for="instructorId" class="form-label fw-bold">Instructor</label>
                        <select name="instructorId" id="instructorId" class="form-select" asp-items="ViewBag.Instructors">
                            <option value="">-- Selecciona Instructor --</option>
                        </select>
                    </div>

                    <!-- Lista de JCF activos -->
                    <div class="mb-3">
                        <label for="jcfId" class="form-label fw-bold">JCF</label>
                        <select name="jcfId" id="jcfId" class="form-select" asp-items="ViewBag.Jcfs">
                            <option value="">-- Selecciona JCF --</option>
                        </select>
                    </div>

                    <!-- Observaciones -->
                    <div class="mb-3">
                        <label for="observaciones" class="form-label fw-bold">Observaciones</label>
                        <textarea name="observaciones" id="observaciones" class="form-control"></textarea>
                    </div>

                    <!-- Botón asignar -->
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-check"></i> Asignar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Panel principal derecho -->
    <div class="col-md-9">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-bold">Asignaciones JCF ↔ Instructor</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Instructor</th>
                                <th>JCF</th>
                                <th>Status</th>
                                <th>Inicio</th>
                                <th>Fin</th>
                                <th>Observaciones</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Assignations != null && Model.Assignations.Any())
                            {
                                @foreach (var a in Model.Assignations)
                                {
                                    <tr>
                                        <td>
                                            <strong>@a.Instructor?.FullName</strong><br />
                                            <small class="text-muted">@a.Instructor?.Email</small>
                                        </td>

                                        <td>
                                            <strong>@a.Jcf?.FullName</strong><br />
                                            <small class="text-muted">@a.Jcf?.Email</small>
                                        </td>

                                        <td>
                                            @if (a.Status == "Activo")
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-circle"></i> Activo
                                                </span>
                                            }
                                            else if (a.Status == "Finalizado")
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-times-circle"></i> Finalizado
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-info-circle"></i> @a.Status
                                                </span>
                                            }
                                        </td>

                                        <td>@a.EffectiveStartDate.ToShortDateString()</td>
                                        <td>@a.EffectiveEndDate?.ToShortDateString()</td>
                                        <td>@a.Observaciones</td>

                                        <td class="text-end">
                                            <form asp-action="Finalizar" asp-controller="JcfAssignations" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@a.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        @(a.Status == "Finalizado" ? "disabled" : "")>
                                                    <i class="fas fa-times"></i> Finalizar
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">No hay asignaciones registradas.</td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <span>Total de asignaciones: @Model.TotalCount</span>
                <nav>
                    <ul class="pagination mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>



<!-- Modal de confirmación -->
<div class="modal fade" id="confirmBulkDeleteModal" tabindex="-1" aria-labelledby="confirmBulkDeleteLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="confirmBulkDeleteLabel">Confirmar eliminación</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        ¿Estás seguro de que deseas eliminar los usuarios seleccionados? Esta acción no se puede deshacer.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" form="bulkDeleteForm" class="btn btn-danger">Sí, eliminar</button>
      </div>
    </div>
  </div>
</div>

@section Toasts {
    @if (TempData["ToastMessage"] != null)
    {
        <div class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["ToastMessage"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" 
                        data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        // Seleccionar/deseleccionar todos los checkboxes
        document.getElementById("selectAll").addEventListener("change", function () {
            var items = document.querySelectorAll(".selectItem");
            for (var i = 0; i < items.length; i++) {
                items[i].checked = this.checked;
            }
        });
    </script>
}
