@using DemoMvc.Models
@model ApplicationUser

@{
    ViewData["Title"] = "Detalles del Usuario";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-bold">Detalles del Usuario</span>
                <a asp-action="Index" class="btn btn-sm btn-secondary">
                    <i class="fas fa-arrow-left"></i> Volver a la lista
                </a>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4 fw-bold">Correo</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4 fw-bold">Nombre de Usuario</dt>
                    <dd class="col-sm-8">@Model.UserName</dd>

                    <dt class="col-sm-4 fw-bold">Nombre Completo</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>

                    <dt class="col-sm-4 fw-bold">Nombre</dt>
                    <dd class="col-sm-8">@Model.FirstName</dd>

                    <dt class="col-sm-4 fw-bold">Apellido</dt>
                    <dd class="col-sm-8">@Model.LastName</dd>

                    <dt class="col-sm-4 fw-bold">Estado</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </dd>

                    <dt class="col-sm-4 fw-bold">Fecha de Creación</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <!-- Campo Rol -->
                    <dt class="col-sm-4 fw-bold">Roles</dt>
                    <dd class="col-sm-8">
                        @if (ViewBag.Roles != null && ((IList<string>)ViewBag.Roles).Count > 0)
                        {
                            foreach (var role in (IList<string>)ViewBag.Roles)
                            {
                                <span class="badge bg-info text-dark me-1">@role</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Sin roles asignados</span>
                        }
                    </dd>
                </dl>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
                        <i class="fas fa-edit"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash-alt"></i> Eliminar
                    </a>
                </div>
            </div>
            <div class="card-footer text-muted">
                Información detallada del usuario seleccionado.
            </div>
        </div>
    </div>
</div>
