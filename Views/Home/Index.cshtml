@{
    ViewData["Title"] = "Home Page";
}

<div class="container text-center mt-5">
    <!-- Hero Section -->
    <div class="row">
        <div class="col">
            <h1 class="display-4 fw-bold">KCM-JCF Reports</h1>
            <p class="lead">La forma más rápida y eficiente de gestionar tus reportes</p>
            <a class="btn btn-primary btn-lg mt-3" asp-controller="Reports" asp-action="Index">
                Comenzar ahora
            </a>
        </div>
    </div>

    <!-- Highlights Section -->
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-speedometer2 display-4 text-primary mb-3"></i>
                    <h5 class="card-title">Reportes más fáciles y rápidos</h5>
                    <p class="card-text">Genera reportes en menos pasos, con una interfaz clara y optimizada para tu flujo de trabajo.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mt-4 mt-md-0">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-shield-check display-4 text-success mb-3"></i>
                    <h5 class="card-title">Autorización optimizada</h5>
                    <p class="card-text">Flujos de autorización más ágiles y transparentes, reduciendo tiempos de espera y errores.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4 mt-4 mt-md-0">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-send-check display-4 text-info mb-3"></i>
                    <h5 class="card-title">Envío a RI más eficiente</h5>
                    <p class="card-text">Automatiza el envío de reportes a RI con trazabilidad y confirmación inmediata.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="row mt-5">
        <div class="col">
            <h3 class="fw-bold">Empieza a optimizar tus reportes hoy</h3>
            <a class="btn btn-success btn-lg mt-3" asp-controller="Reports" asp-action="Index">
                Ir a Reportes
            </a>
        </div>
    </div>
</div>
