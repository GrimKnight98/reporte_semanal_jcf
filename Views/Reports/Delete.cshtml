@model DemoMvc.Models.Report

@{
    ViewData["Title"] = "Eliminar Reporte";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm mb-4 border-danger">
            <div class="card-header d-flex justify-content-between align-items-center bg-danger bg-opacity-10">
                <span class="fw-bold text-danger">Eliminar Reporte</span>
                <a asp-action="Index" class="btn btn-sm btn-secondary">
                    <i class="fas fa-arrow-left"></i> Cancelar
                </a>
            </div>
            <div class="card-body">
                <h5 class="text-danger mb-3">¿Estás seguro que deseas eliminar este reporte?</h5>

                <dl class="row">
                    <dt class="col-sm-4 fw-bold">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 fw-bold">Fecha inicio</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToShortDateString()</dd>

                    <dt class="col-sm-4 fw-bold">Fecha fin</dt>
                    <dd class="col-sm-8">@Model.EndDate.ToShortDateString()</dd>

                    <dt class="col-sm-4 fw-bold">Estado</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4 fw-bold">Creado por</dt>
                    <dd class="col-sm-8">@Model.CreatedBy?.UserName</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt"></i> Eliminar
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-muted">
                Esta acción no se puede deshacer. Al eliminar el reporte se borrarán también sus detalles y actividades asociadas.
            </div>
        </div>
    </div>
</div>
