@model DemoMvc.ViewModels.Reports.ReportPagedViewModel

@{
    ViewData["Title"] = "Reportes";
}

<h1 class="mb-4">Reportes</h1>

<div class="row">

    <!-- 🔍 PANEL DE FILTROS -->
    <div class="col-md-3">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white fw-bold">
                Filtros
            </div>
            <div class="card-body">

                <form asp-action="Index" method="get">

                    <!-- Status -->
                    <div class="mb-3">
                        <label class="form-label">Estatus</label>
                        <select name="status" class="form-select">
                            <option value="">Todos</option>
                            @foreach (var s in Enum.GetValues(typeof(DemoMvc.Models.ReportStatus)))
                            {
                                <option value="@s">
    @(s.ToString() switch
    {
        "Draft" => "Borrador",
        "SubmittedToInstructor" => "Enviado a Instructor",
        "Approved" => "Aprobado",
        "SubmittedToRI" => "Enviado a RI",
        "Rejected" => "Rechazado",
        _ => s.ToString()
    })
</option>
                            }
                        </select>
                    </div>

                    <!-- Fecha inicio -->
                    <div class="mb-3">
                        <label class="form-label">Fecha inicio</label>
                        <input type="date" name="startDate"
                               value="@(Model.StartDate?.ToString("yyyy-MM-dd"))"
                               class="form-control" />
                    </div>

                    <!-- Fecha fin -->
                    <div class="mb-3">
                        <label class="form-label">Fecha fin</label>
                        <input type="date" name="endDate"
                               value="@(Model.EndDate?.ToString("yyyy-MM-dd"))"
                               class="form-control" />
                    </div>

                    <!-- PageSize -->
                    <div class="mb-3">
                        <label class="form-label">Registros por página</label>
                        <select name="pageSize" class="form-select">
                            <option value="5" selected="@(Model.PageSize == 5)">5</option>
                            <option value="10" selected="@(Model.PageSize == 10)">10</option>
                            <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success w-100">
                        Filtrar
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                        Limpiar
                    </a>

                </form>
            </div>
        </div>
    </div>

    <!-- 📊 TABLA -->
    <div class="col-md-9">
        <div class="card shadow-sm mb-4">

            <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
                <span class="fw-bold">Lista de Reportes</span>
                <a asp-action="Create" class="btn btn-sm btn-success">
                    <i class="fas fa-plus"></i> Nuevo Reporte
                </a>
            </div>

            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Inicio</th>
                                <th>Fin</th>
                                <th>Estado</th>
                                <th>Creado por</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                        @if (Model.Items.Any())
                        {
                            @foreach (var report in Model.Items)
                            {
                                <tr>
                                    <td>@report.Id</td>
                                    <td>@report.StartDate.ToShortDateString()</td>
                                    <td>@report.EndDate.ToShortDateString()</td>

                                    <td>
                                        @switch (report.Status)
                                        {
                                            case ReportStatus.Draft:
                                                @:<span class="badge bg-secondary">Borrador</span>
                                                break;
                                            case ReportStatus.SubmittedToInstructor:
                                                @:<span class="badge bg-info">Instructor</span>
                                                break;
                                            case ReportStatus.Approved:
                                                @:<span class="badge bg-success">Aprobado</span>
                                                break;
                                            case ReportStatus.SubmittedToRI:
                                                @:<span class="badge bg-warning">RI</span>
                                                break;
                                            case ReportStatus.Rejected:
                                                @:<span class="badge bg-danger">Rechazado</span>
                                                break;
                                        }
                                    </td>

                                    <td>@report.CreatedBy?.UserName</td>

                                    <td class="text-end">
                                        <div class="btn-group gap-2">

                                            <a asp-action="Details" asp-route-id="@report.Id"
                                               class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            @if (report.Status == ReportStatus.Draft)
                                            {
                                                <a asp-action="Delete" asp-route-id="@report.Id"
                                                   class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            }

                                            @if (report.Status == ReportStatus.Approved)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#confirmRiModal"
                                                        data-report-id="@report.Id">
                                                    <i class="fas fa-paper-plane"></i>
                                                </button>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    No hay reportes con esos filtros
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- 📄 FOOTER -->
            <div class="card-footer d-flex justify-content-between align-items-center">

                <span>
                    Mostrando @Model.FromItem - @Model.ToItem de @Model.TotalItems
                </span>

                <nav>
                    <ul class="pagination mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-status="@Model.Status"
                                   asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                                   asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>

            </div>

        </div>
    </div>
</div>

<!-- 🔥 Modal RI (igual que el tuyo) -->
<div class="modal fade" id="confirmRiModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5>Confirmar envío a RI</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                ¿Seguro que deseas enviar este reporte?
            </div>

            <div class="modal-footer justify-content-center">
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" id="reportIdInput" />
                    <input type="hidden" name="targetStatus" value="SubmittedToRI" />

                    <button type="submit" class="btn btn-primary">
                        Enviar
                    </button>
                </form>

                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('confirmRiModal')
.addEventListener('show.bs.modal', function (event) {
    var button = event.relatedTarget;
    var reportId = button.getAttribute('data-report-id');
    document.getElementById('reportIdInput').value = reportId;
});
</script>