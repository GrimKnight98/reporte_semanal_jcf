@model IEnumerable<DemoMvc.Models.Report>

@{
    ViewData["Title"] = "Reportes";
}

<h1 class="mb-4">Reportes</h1>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
                <span class="fw-bold">Lista de Reportes</span>
                <div>
                    <a asp-action="Create" class="btn btn-sm btn-success">
                        <i class="fas fa-plus"></i> Nuevo Reporte
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Fecha inicio</th>
                                <th>Fecha fin</th>
                                <th>Estado</th>
                                <th>Creado por</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>@report.Id</td>
                                    <td>@report.StartDate.ToShortDateString()</td>
                                    <td>@report.EndDate.ToShortDateString()</td>
                                    <td>
                                        @switch (report.Status)
                                        {
                                            case ReportStatus.Draft:
                                                @:<span class="badge bg-secondary">Borrador</span>
                                                break;
                                            case ReportStatus.SubmittedToInstructor:
                                                @:<span class="badge bg-info">Enviado a Instructor</span>
                                                break;
                                            case ReportStatus.Approved:
                                                @:<span class="badge bg-success">Aprobado</span>
                                                break;
                                            case ReportStatus.SubmittedToRI:
                                                @:<span class="badge bg-warning">Enviado a RI</span>
                                                break;
                                            case ReportStatus.Rejected:
                                                @:<span class="badge bg-danger">Rechazado</span>
                                                break;
                                        }
                                    </td>
                                    <td>@report.CreatedBy?.UserName</td>
                                    <td class="text-end">
                                        <div class="btn-group gap-2" role="group">
                                            <!-- Botón Detalles -->
                                            <a asp-action="Details" asp-route-id="@report.Id" class="btn btn-sm btn-outline-info" title="Detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            <!-- Botón Eliminar: solo si Draft -->
                                            @if (report.Status == ReportStatus.Draft)
                                            {
                                                <a asp-action="Delete" asp-route-id="@report.Id" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            }

                                            <!-- Botón Enviar a RI: solo si Approved -->
                                            @if (report.Status == ReportStatus.Approved)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#confirmRiModal"
                                                        data-report-id="@report.Id"
                                                        title="Enviar a RI">
                                                    <i class="fas fa-paper-plane"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">No hay reportes registrados.</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer text-muted">
                Total de reportes: @(Model?.Count() ?? 0)
            </div>
        </div>
    </div>
</div>

<!-- Modal de confirmación para Enviar a RI -->
<div class="modal fade" id="confirmRiModal" tabindex="-1" aria-labelledby="confirmRiLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="confirmRiLabel">Confirmar envío a RI</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body text-center">
        <p>¿Seguro que deseas enviar este reporte a RI?<br />
        Una vez enviado, ya no podrás modificarlo.</p>
      </div>
      <div class="modal-footer justify-content-center">
        <form id="confirmRiForm" asp-action="UpdateStatus" asp-controller="Reports" method="post" class="d-inline">
            <input type="hidden" name="id" id="reportIdInput" />
            <input type="hidden" name="targetStatus" value="SubmittedToRI" />
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-paper-plane"></i> Sí, enviar
            </button>
        </form>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
      </div>
    </div>
  </div>
</div>

<script>
    var confirmRiModal = document.getElementById('confirmRiModal');
    confirmRiModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var reportId = button.getAttribute('data-report-id');
        var input = document.getElementById('reportIdInput');
        input.value = reportId;
    });
</script>
