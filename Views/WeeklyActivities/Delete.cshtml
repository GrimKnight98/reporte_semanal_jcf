@model DemoMvc.Models.WeeklyActivity

@{
    ViewData["Title"] = "Eliminar Actividad";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm mb-4 border-danger">
            <div class="card-header d-flex justify-content-between align-items-center bg-danger bg-opacity-10">
                <span class="fw-bold text-danger">Eliminar Actividad</span>
                <a asp-action="Index" class="btn btn-sm btn-secondary">
                    <i class="fas fa-arrow-left"></i> Cancelar
                </a>
            </div>
            <div class="card-body">
                <h5 class="text-danger mb-3">¿Estás seguro que deseas eliminar esta actividad?</h5>

                <dl class="row">
                    <dt class="col-sm-4 fw-bold">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 fw-bold">Nombre</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4 fw-bold">Descripción</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4 fw-bold">Creado por</dt>
                    <dd class="col-sm-8">@Model.CreatedByUser?.Email</dd>

                    <dt class="col-sm-4 fw-bold">Fecha creación</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 fw-bold">Última actualización</dt>
                    <dd class="col-sm-8">
                        @(Model.UpdatedAt.HasValue ? Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-end mt-4">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt"></i> Eliminar
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-muted">
                Esta acción no se puede deshacer.
            </div>
        </div>
    </div>
</div>
