@model DemoMvc.Models.WeeklyActivity

@{
    ViewData["Title"] = "Detalle de actividad semanal";
}

<h1 class="mb-4">Detalle de actividad semanal</h1>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-success">
            <div class="card-header bg-success bg-opacity-25 text-success fw-bold">
                <i class="fas fa-eye"></i> Información de la actividad
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Descripción</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Creado por</dt>
                    <dd class="col-sm-8">@Model.CreatedByUser?.Email</dd>

                    <dt class="col-sm-4">Fecha creación</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Última actualización</dt>
                    <dd class="col-sm-8">
                        @(Model.UpdatedAt.HasValue ? Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Volver a la lista
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-success">
                    <i class="fas fa-edit"></i> Editar
                </a>
            </div>
        </div>
    </div>
</div>
