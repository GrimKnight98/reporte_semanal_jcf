@model DemoMvc.Models.ReportDetail

@{
    ViewData["Title"] = "Editar Detalle del Reporte";
}

<h1 class="mb-4">Editar Detalle</h1>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark fw-bold">
                Editar Detalle de Reporte
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ReportId" />

                    <!-- Observaciones primero -->
                    <div class="mb-3">
                        <label asp-for="Observations" class="form-label fw-bold">
                            ¿Tuviste dudas? ¿Quién te ayudó a resolverlas?
                        </label>
                        <textarea asp-for="Observations" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Observations" class="text-danger"></span>
                    </div>

                    <!-- Training Sessions después -->
                    <div class="mb-3">
                        <label asp-for="TrainingSessions" class="form-label fw-bold">
                            En esta semana ¿recibiste capacitación, pláticas o algún taller? Cuéntanos de qué:
                        </label>
                        <textarea asp-for="TrainingSessions" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="TrainingSessions" class="text-danger"></span>
                    </div>

                    <!-- Select multiple con chips (Tom Select) -->
                    <div class="mb-3">
                        <label for="ActivitiesIds" class="form-label fw-bold">Actividades Semanales</label>
                        <select id="ActivitiesIds" name="ActivitiesIds" asp-items="ViewBag.ActivitiesList" multiple></select>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <a asp-action="Details" asp-controller="Reports" asp-route-id="@Model.ReportId" 
                           class="btn btn-outline-secondary me-2">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <!-- Tom Select CSS & JS -->
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new TomSelect("#ActivitiesIds", {
                plugins: ['remove_button'],
                placeholder: "Selecciona actividades",
                create: false
            });
        });
    </script>
}

