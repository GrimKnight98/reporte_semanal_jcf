@model DemoMvc.Models.ReportDetail

@{
    ViewData["Title"] = "Agregar Detalle al Reporte";
}

<h1 class="mb-4">Agregar Detalle</h1>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white fw-bold">
                Nuevo Detalle de Reporte
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <input type="hidden" asp-for="ReportId" />

                    <div class="mb-3">
                        <label asp-for="TrainingSessions" class="form-label fw-bold"></label>
                        <textarea asp-for="TrainingSessions" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="TrainingSessions" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Observations" class="form-label fw-bold"></label>
                        <textarea asp-for="Observations" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Observations" class="text-danger"></span>
                    </div>

                    <!-- Select multiple con chips (Choices.js) -->
                    <div class="mb-3">
                        <label for="ActivitiesIds" class="form-label fw-bold">Actividades Semanales</label>
                        <select id="ActivitiesIds" name="ActivitiesIds" asp-items="ViewBag.ActivitiesList" multiple></select>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <a asp-action="Details" asp-controller="Reports" asp-route-id="@Model.ReportId" 
                           class="btn btn-outline-secondary me-2">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Guardar Detalle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <!-- Choices.js -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const element = document.getElementById('ActivitiesIds');
            new Choices(element, {
                removeItemButton: true,
                placeholderValue: 'Selecciona actividades',
                searchPlaceholderValue: 'Buscar...',
                shouldSort: false
            });
        });
    </script>
}
