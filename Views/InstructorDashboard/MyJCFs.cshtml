@model DemoMvc.Models.MyJCFsViewModel

@{
    ViewData["Title"] = "Mis JCFs";
}

<h1 class="mb-4">Mis JCFs Asignados</h1>

<div class="row">
    <!-- Panel lateral de búsqueda -->
    <div class="col-md-3">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white fw-bold">
                Buscar JCF
            </div>
            <div class="card-body">
                <form asp-action="MyJCFs" method="get">
                    <div class="input-group">
                        <input type="text" name="search" value="@Model.Search"
                               class="form-control" placeholder="Nombre de JCF" />
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                    </div>
                </form>
                @if (!string.IsNullOrWhiteSpace(Model.Search))
                {
                    <div class="mt-3">
                        <a asp-action="MyJCFs" class="btn btn-sm btn-outline-secondary w-100">
                            <i class="fas fa-list"></i> Ver todos
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Panel principal con la tabla -->
    <div class="col-md-9">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-bold">Lista de JCFs</span>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                       <thead>
    <tr>
        <th>Nombre</th>
        <th>Fecha Inicio</th>
        <th>Fecha Fin</th>
        <th>Estado</th>
        <th>Observaciones</th>
        <th class="text-end">Acciones</th>
    </tr>
</thead>
<tbody>
@if (Model.Asignaciones != null && Model.Asignaciones.Any())
{
    @foreach (var asignacion in Model.Asignaciones)
    {
        <tr>
            <td>@asignacion.Jcf?.UserName</td>
            <td>@asignacion.EffectiveStartDate.ToShortDateString()</td>
            <td>
                @(asignacion.EffectiveEndDate.HasValue 
                    ? asignacion.EffectiveEndDate.Value.ToShortDateString() 
                    : "—")
            </td>
            <td>
                @if (asignacion.Status == "Activo")
                {
                    <span class="badge bg-success">
                        <i class="fas fa-check"></i> Activo
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        <i class="fas fa-times"></i> Inactivo
                    </span>
                }
            </td>
            <td>@asignacion.Observaciones</td>
            <td class="text-end">
                <a asp-action="Details" asp-route-id="@asignacion.Id" class="btn btn-sm btn-outline-info">
                    <i class="fas fa-eye"></i> Detalles
                </a>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="6" class="text-center text-muted">No tienes JCFs asignados.</td>
    </tr>
}
</tbody>

                    </table>
                </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
                <span>Total de asignaciones: @Model.TotalCount</span>
                <!-- Paginación -->
                <nav>
                    <ul class="pagination mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="MyJCFs" asp-route-page="@i" asp-route-search="@Model.Search">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>
